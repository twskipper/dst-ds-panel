FROM golang:1.21-alpine AS builder

RUN apk add --no-cache nodejs npm make

WORKDIR /src
COPY . .

RUN cd frontend && npm install && cd ..
RUN make build

FROM alpine:latest

RUN apk add --no-cache ca-certificates docker-cli

WORKDIR /app
COPY --from=builder /src/backend/dst-ds-panel /app/dst-ds-panel
COPY --from=builder /src/config.json /app/config.json

EXPOSE 8080
CMD ["/app/dst-ds-panel"]
